# Frontend (build-time)
VITE_BFF_URL=https://xx-xx-xx-xx.onrender.com
VITE_BASE_PATH=/

# Backend (runtime)
OPENAI_API_KEY=
CORS_ORIGIN=https://plamarque.github.io

# Modèles IA (optionnel — contrôle des coûts)
# Images : gpt-image-1.5, gpt-image-1-mini, dall-e-3 (déprécié 05/2026)
# AI_IMAGE_MODEL_RECIPE=gpt-image-1.5
# AI_IMAGE_MODEL_INGREDIENT=gpt-image-1-mini
# AI_IMAGE_MODEL_COOKING_STEP=gpt-image-1-mini
# Qualité : GPT Image = low|medium|high ; DALL-E = standard|hd
# AI_IMAGE_QUALITY_RECIPE=low
# AI_IMAGE_QUALITY_INGREDIENT=low
# AI_IMAGE_QUALITY_COOKING_STEP=low
# Chat : gpt-4o-mini, gpt-4o, etc.
# AI_CHAT_MODEL=gpt-4o-mini
# AI_CHAT_MODEL_PARSE=
# AI_CHAT_MODEL_STEP_TIMER=
# AI_CHAT_MODEL_REORDER=

# Cache des images générées (backend)
# Dossier de cache local (filesystem) ; utilisé même sans stockage objet.
GENERATED_IMAGE_CACHE_DIR=.cache/generated-images
# Base URL publique pour composer les liens retournés par l'API (sinon auto depuis la requête).
# GENERATED_IMAGE_BASE_URL=https://cookies-et-coquilettes-bff.onrender.com

# Token admin pour les endpoints de purge manuelle du cache:
# - POST /api/admin/generated-images/purge-key
# - POST /api/admin/generated-images/purge-ingredient
# GENERATED_IMAGE_ADMIN_TOKEN=change-me

# Stockage objet persistant optionnel (API S3-compatible, ex: Cloudflare R2).
# Important: le backend n'active le stockage objet que si les 4 variables
# endpoint + bucket + access key id + secret access key sont toutes définies.
# Endpoint S3-compatible (R2: https://<accountid>.r2.cloudflarestorage.com)
# GENERATED_IMAGE_S3_ENDPOINT=
# Région (R2: auto ; AWS S3: ex. eu-west-1)
# GENERATED_IMAGE_S3_REGION=auto
# Nom du bucket cible
# GENERATED_IMAGE_S3_BUCKET=cookies-et-coquilettes-generated-images
# Identifiants API (Cloudflare R2 API token / AWS IAM key)
# GENERATED_IMAGE_S3_ACCESS_KEY_ID=
# GENERATED_IMAGE_S3_SECRET_ACCESS_KEY=
# Session token temporaire (optionnel ; laisser vide pour clés long-terme)
# GENERATED_IMAGE_S3_SESSION_TOKEN=
# Préfixe de chemin dans le bucket
# GENERATED_IMAGE_S3_PREFIX=generated-images
